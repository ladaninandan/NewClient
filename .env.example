# Copy this file to .env and fill in your Supabase values.
# Get them from: Supabase Dashboard → Project Settings → API
# Use "Project URL" and "anon public" key.

# Admin login (optional; defaults: admin@example.com / admin123)
REACT_APP_ADMIN_EMAIL=admin@example.com
REACT_APP_ADMIN_PASSWORD=admin123

# Razorpay (optional; if set, form opens Razorpay after validation and saves payment_id on success)
# Create orders via backend: use api/create-order (Vercel) or your own endpoint. Add columns payment_id, razorpay_order_id to Supabase registrations table.
REACT_APP_RAZORPAY_KEY_ID=rzp_test_SSz4LnWinp8MLs
REACT_APP_RAZORPAY_ORDER_API=https://csxxwfnjexvofiqyribe.supabase.co/functions/v1/create-order
